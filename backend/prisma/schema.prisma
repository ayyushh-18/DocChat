generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum ChatStatus {
    QUEUED
    PROCESSING
    READY
    FAILED
}

enum IngestionRunStatus {
    STARTED
    SUCCESS
    FAILED
}

enum Providers {
    OPENAI
    ANTHROPIC
    GOOGLE
    XAI
    OPENROUTER
}

model User {
    id           String        @id @unique @default(uuid())
    fullname     String?
    username     String?       @unique
    password     String?
    refreshToken String?       @map("refresh_token")
    createdAt    DateTime      @default(now()) @map("created_at")
    email        String?       @unique
    isVerified   Boolean       @default(false) @map("is_verified")
    isAdmin      Boolean       @default(false) @map("is_admin")
    apikeys      ApiKey[]
    chats        Chat[]
    usageEvents  UsageEvents[]
    auditEvents  AuditEvent[]

    @@index([isAdmin, createdAt])
}

model Chat {
    id             String        @id @unique @default(uuid())
    name           String
    userId         String        @map("user_id")
    status         ChatStatus    @default(QUEUED)
    createdAt      DateTime      @default(now()) @map("created_at")
    failedAt       DateTime?     @map("failed_at")
    failureReason  String?       @map("failure_reason")
    collectionName String?       @map("collection_name")
    shareToken     String?       @unique @map("share_token")
    createdBy      User          @relation(fields: [userId], references: [id])
    chatSources    ChatSource[]  @relation("ChatToChatSource")
    messages       ChatMessage[]
    usageEvents    UsageEvents[]
    ingestionRuns  IngestionRun[]
    auditEvents    AuditEvent[]

    @@index([userId, createdAt])
    @@index([status, createdAt])
}

model ChatSource {
    id               String         @id @unique @default(uuid())
    heading          String
    isVectorLess     Boolean        @default(false) @map("is_vector_less")
    documentationUrl String         @map("documentation_url")
    totalPages       Int?           @map("total_pages")
    pagesIndexed     DocumentPage[]
    chats            Chat[]         @relation("ChatToChatSource")
    collectionName   String?        @default("") @map("collection_name")
    documentTree     DocumentTree?
    createdAt        DateTime       @default(now()) @map("created_at")
    ingestionRuns    IngestionRun[]
    scrapeLimit      Int?           @map("scrape_limit")

    @@unique([documentationUrl, isVectorLess])
}

model IngestionRun {
    id            String             @id @unique @default(uuid())
    chatId        String             @map("chat_id")
    chatSourceId  String             @map("chat_source_id")
    status        IngestionRunStatus @default(STARTED)
    startedAt     DateTime           @default(now()) @map("started_at")
    finishedAt    DateTime?          @map("finished_at")
    errorCode     String?            @map("error_code")
    errorMessage  String?            @map("error_message")
    pagesCrawled  Int                @default(0) @map("pages_crawled")
    pagesFailed   Int                @default(0) @map("pages_failed")
    chat          Chat               @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatSource    ChatSource         @relation(fields: [chatSourceId], references: [id], onDelete: Cascade)

    @@index([chatId, startedAt])
    @@index([chatSourceId, startedAt])
    @@index([status, startedAt])
}

model DocumentPage {
    id           String     @id @unique @default(uuid())
    heading      String
    pageUrl      String     @map("page_url")
    chatSourceId String     @map("chat_source_id")
    startIndex   Int?       @map("start_index")
    endIndex     Int?       @map("end_index")
    chatSource   ChatSource @relation(fields: [chatSourceId], references: [id], onDelete: Cascade)
}

model DocumentTree {
    id           String     @id @unique @default(uuid())
    chatSourceId String     @unique @map("chat_source_id")
    sourceData   String     @map("source_data")
    treeData     Json       @map("tree_data")
    createdAt    DateTime   @default(now()) @map("created_at")
    chatSource   ChatSource @relation(fields: [chatSourceId], references: [id], onDelete: Cascade)
}

model ChatMessage {
    id           String              @id @unique @default(uuid())
    chatId       String              @map("chat_id")
    userPrompt   String              @map("user_prompt")
    llmResponse  String              @map("llm_response")
    llmModel     String              @map("llm_model")
    createdAt    DateTime            @default(now()) @map("created_at")
    sourceChunks ChatMessageSource[]
    usageEvents  UsageEvents[]
    chat         Chat                @relation(fields: [chatId], references: [id])

    @@index([chatId, createdAt])
}

model ChatMessageSource {
    id            String      @id @unique @default(uuid())
    chunkText     String      @map("chunk_text")
    heading       String
    pageUrl       String      @map("page_url")
    chatMessageId String      @map("chat_message_id")
    chatMessage   ChatMessage @relation(fields: [chatMessageId], references: [id])
    score         Int         @default(0) @map("score")
}

model ApiKey {
    id           String        @id @unique @default(uuid())
    userId       String        @map("user_id")
    name         String
    createdAt    DateTime      @default(now()) @map("created_at")
    encryptedKey String        @unique @map("encrypted_key")
    iv           String
    provider     Providers
    tag          Bytes
    user         User          @relation(fields: [userId], references: [id])
    usageEvents  UsageEvents[]
}

model UsageEvents {
    id           String       @id @unique @default(uuid())
    userId       String       @map("user_id")
    messageId    String?      @map("message_id")
    apikeyId     String?      @map("apikey_id")
    chatId       String?      @map("chat_id")
    inputTokens  Int          @map("input_tokens")
    outputTokens Int          @map("output_tokens")
    estimatedCostUsd Decimal   @default(0) @map("estimated_cost_usd") @db.Decimal(12, 6)
    priceVersion  String?     @map("price_version")
    timestamp    DateTime     @default(now())
    apiKey       ApiKey?      @relation(fields: [apikeyId], references: [id])
    message      ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
    user         User         @relation(fields: [userId], references: [id])
    chat         Chat?        @relation(fields: [chatId], references: [id], onDelete: SetNull)

@@index([userId, timestamp])
@@index([messageId])
@@index([apikeyId])
}

model AuditEvent {
    id        String   @id @unique @default(uuid())
    type      String
    userId    String?  @map("user_id")
    chatId    String?  @map("chat_id")
    metadata  Json?
    createdAt DateTime @default(now()) @map("created_at")
    user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
    chat      Chat?    @relation(fields: [chatId], references: [id], onDelete: SetNull)

    @@index([createdAt])
    @@index([type, createdAt])
}
